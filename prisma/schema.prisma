generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id    String  @id @default(cuid()) @map("_id") // mapping this id is very important because mongoDB uses _id for our ids
  name  String?
  email String  @unique
}
